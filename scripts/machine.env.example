INFISICAL_MACHINE_CLIENT_ID="your-client-id"
INFISICAL_MACHINE_CLIENT_SECRET="your-client-secret"
INFISICAL_PROJECT_ID="your-project-id"
# Infisical secrets environment for this machine — also selects git branch in scripts/auto_deploy.sh:
#   staging → origin/demo, make deploy demo
#   prod    → origin/main, make deploy prod
INFISICAL_SECRET_ENV="staging"
INFISICAL_DISABLE_UPDATE_CHECK=true
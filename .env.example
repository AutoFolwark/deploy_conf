# Copy to .env in this repository root (see .gitignore — .env is not committed).
# If you still have dev/.env from an older layout: mv dev/.env .env
#
# Makefile and run.ps1 pass --env-file .env when the file exists, for any compose profile.
# Manual compose: from repo root, e.g.
#   docker compose --env-file .env -f general/docker-compose.base.yml -f dev/docker-compose.dev.yml up
#   docker compose --env-file .env -f demo/docker-compose.demo.yml up
#
# ---------------------------------------------------------------------------
# Service images (optional) — defaults in general/docker-compose.base.yml are ivanskrb21/*:main
# ---------------------------------------------------------------------------

IMAGE_AUTH_SERVICE=autofolwarkwork/auth_service:dev
IMAGE_API_SERVICE=autofolwarkwork/api_service:dev
IMAGE_PAYMENT_SERVICE=autofolwarkwork/payment_service:dev
IMAGE_CARFAX_SERVICE=autofolwarkwork/carfax_service:dev
IMAGE_CALCULATOR_SERVICE=autofolwarkwork/calculator_service:dev
IMAGE_FAVORITES_SERVICE=autofolwarkwork/favorites_service:dev
IMAGE_BID_SERVICE=autofolwarkwork/bid_service:dev
IMAGE_ORDER_SERVICE=autofolwarkwork/order_service:dev
IMAGE_FILE_SERVICE=autofolwarkwork/file_service:dev
IMAGE_NOTIFICATION_SERVICE=autofolwarkwork/notification_service:dev

# Add DB_*, RABBITMQ_*, AWS_*, etc. here as needed for your environment.
